# SelfFork v3 deploy — copy to `.env` and customise.
#
# Required to run: SELFFORK_PORT, MODEL_ENDPOINT.
# Everything else has sensible defaults.

# ── SelfFork host port (browser opens http://<server>:<port>/) ──────────
SELFFORK_PORT=8765

# ── Model endpoint (external — Self Jr's brain) ─────────────────────────
# Set to wherever Gemma 4 is served. Common scenarios:
#   - Lab Mac via Tailscale:   http://100.x.x.x:8080
#   - Rental GPU box:          https://gpu.example.com
#   - Self-hosted Ollama:      http://host.docker.internal:11434
#   - Anthropic API fallback:  https://api.anthropic.com
MODEL_ENDPOINT=http://host.docker.internal:8080
MODEL_PROTOCOL=openai
MODEL_NAME=gemma-4-26b-a4b-it-4bit

# ── Telegram bridge (optional) ──────────────────────────────────────────
# Get a bot token from @BotFather, then set the public webhook URL.
# Leave both blank to disable Telegram integration.
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_URL=

# ── Soft confirmation window (hours) ───────────────────────────────────
# Destructive actions wait this long for explicit operator approval
# via Telegram. Silence = automatic cancel (fail-safe NO).
SOFT_CONFIRM_HOURS=4
